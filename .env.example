# ──────────────────────────────────────────────────────────────────────────────
# SmartCheck — Environment Variables
# Copy this file to .env and fill in the values before running the app.
# Never commit your actual .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Flask secret key — used to sign session cookies and CSRF tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Set to "production" to enable production-mode guards (secure cookies, strict env checks).
# Leave unset or set to "development" for local dev.
FLASK_ENV=development

# Set to "0" to disable the Flask reloader/debugger (alternative to FLASK_ENV=production).
FLASK_DEBUG=1

# ── Supabase ───────────────────────────────────────────────────────────────────

# Your Supabase project URL (e.g. https://xxxxxxxxxxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Supabase anonymous/public key — used for RLS-enforced client operations.
SUPABASE_ANON_KEY=

# Supabase service role key — bypasses RLS, used only for admin/server operations.
# Keep this secret — never expose to the browser.
SUPABASE_SERVICE_KEY=

# ── Database ───────────────────────────────────────────────────────────────────

# PostgreSQL connection string for Flask-Session (SQLAlchemy backend).
# On Railway this is set automatically. For local dev use your Supabase direct URL:
# postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# ── Security ───────────────────────────────────────────────────────────────────

# Random salt used to compute SHA-256 integrity hashes over stored face embeddings.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
EMBEDDING_INTEGRITY_SALT=

# ── Rate Limiting ──────────────────────────────────────────────────────────────

# Redis connection URL for Flask-Limiter (e.g. redis://localhost:6379/0).
# Leave empty to fall back to in-memory limiting (single-process only).
REDIS_URL=
